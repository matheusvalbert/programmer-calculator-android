<resources>
    <style name="Theme.ProgrammerCalculator" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:background">@color/dark_dark</item>
        <item name="android:statusBarColor">@color/dark_dark</item>
        <item name="android:navigationBarColor">@color/dark_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="control_button">@color/dark_gray</item>
        <item name="value_button">@color/light_dark</item>
        <item name="button_disabled">@color/disabled_button_dark</item>
        <item name="text_disabled">@color/disabled_text_dark</item>
    </style>
</resources>