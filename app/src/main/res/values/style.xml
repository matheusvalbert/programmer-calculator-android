<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="resultLayout">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginHorizontal">@dimen/padding</item>
    </style>

    <style name="baseRow">
        <item name="android:layout_weight">0.6</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">0dp</item>
    </style>

    <style name="buttonRow">
        <item name="android:layout_weight">1</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">0dp</item>
    </style>

    <style name="resultItem">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textDirection">rtl</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
    </style>

    <style name="baseButton" parent="@style/Widget.AppCompat.Button.Borderless">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:paddingStart">@dimen/padding</item>
        <item name="android:letterSpacing">@dimen/letterSpacing</item>
        <item name="android:textSize">@dimen/textSize</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:background">@drawable/base_null</item>
    </style>

    <style name="baseResult">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">3</item>
        <item name="android:textSize">@dimen/textSize</item>
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">textStart</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:layout_marginHorizontal">@dimen/padding</item>
    </style>

    <style name="button" parent="@style/Widget.AppCompat.Button.Borderless">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_margin">@dimen/margin</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">@dimen/textSize</item>
    </style>

    <style name="controlButton" parent="button">
        <item name="android:background">@drawable/control_button</item>
        <item name="android:textColor">@color/text_color</item>
    </style>

    <style name="valueButton" parent="button">
        <item name="android:background">@drawable/value_button</item>
        <item name="android:textColor">@color/text_color</item>
    </style>

    <style name="operationButton" parent="button">
        <item name="android:background">@drawable/operation_button</item>
        <item name="android:textColor">@color/white</item>
    </style>

</resources>